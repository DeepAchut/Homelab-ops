# cluster.env.example
#
# Documents every environment-specific value used across this repo.
# Copy to cluster.env (gitignored) and fill in your values.
#
# These are NOT injected automatically into manifests — they document
# what to search-and-replace when adapting this repo to your environment.
# Run: grep -r "<placeholder>" kubernetes/ to find all occurrences.

# ── Network ──────────────────────────────────────────────────────────────────

# Peladn always-on base station (Proxmox host + NFS server)
PELADN_IP=192.168.4.150

# Talos K8s control plane VM (on Peladn)
CONTROL_PLANE_IP=192.168.4.172

# RPi4 always-on K8s worker (NodePort endpoint for in-cluster services)
RPI4_WORKER_IP=192.168.4.141

# media-ai-ops LXC — Ollama always-on (AMD 780M ROCm)
OLLAMA_ALWAYS_ON_IP=192.168.4.12
OLLAMA_ALWAYS_ON_URL=http://192.168.4.12:11434

# i9 WOL burst — Ollama GPU burst (RTX 5070, CUDA)
OLLAMA_BURST_IP=192.168.4.110
OLLAMA_BURST_URL=http://192.168.4.110:11434

# monitoring-lxc CT204 (planned Phase 19)
MONITORING_LXC_IP=192.168.4.14

# ── Cluster ───────────────────────────────────────────────────────────────────

# Kubernetes cluster name (used in kubeconfig context, Flux path)
CLUSTER_NAME=homelab

# Flux GitRepository path (must match kubernetes/clusters/<name>/ directory)
FLUX_CLUSTER_PATH=./kubernetes/clusters/homelab

# Git repo URL (Flux GitRepository source)
GIT_REPO_URL=ssh://git@github.com/<your-username>/Homelab-ops

# ── DNS / Domains ─────────────────────────────────────────────────────────────

# Base domain for externally reachable services (via NPM + DuckDNS or similar)
BASE_DOMAIN=yourdomain.duckdns.org

# Per-service subdomains (update n8n/deployment.yaml, grafana, etc.)
N8N_DOMAIN=n8n.yourdomain.duckdns.org
GRAFANA_DOMAIN=grafana.yourdomain.duckdns.org
MEM0_DOMAIN=mem0.yourdomain.duckdns.org

# ── mem0 stack ────────────────────────────────────────────────────────────────

# Ollama model used for mem0 LLM fact extraction
MEM0_LLM_MODEL=gemma4-mem0

# Ollama model used for embeddings (must produce vectors of MEM0_EMBED_DIMS size)
MEM0_EMBED_MODEL=nomic-embed-text
MEM0_EMBED_DIMS=768

# mem0 Qdrant collection name
MEM0_COLLECTION=mem0

# ── Storage ───────────────────────────────────────────────────────────────────

# NFS server for backup cronjobs (Peladn NAS)
NFS_SERVER_IP=192.168.4.150
NFS_MEM0_BACKUP_PATH=/mnt/pvedas/mem0-backups

# ── Node names (Talos — immutable without full node reprovisioning) ───────────
#
# These are baked in at Talos provisioning time and cannot be renamed
# without reprovisioning the node. Documented here for reference.
#
# NODE_CP=<hostname>-talos-cp
# NODE_WORKER_ALWAYS_ON=<hostname>-talos-worker   # RPi4
# NODE_WORKER_BURST_NUC=<hostname>-talos-worker   # Intel NUC (WOL)
# NODE_WORKER_BURST_R610=<hostname>-talos-worker  # Dell R610 (WOL)
# NODE_WORKER_BURST_GPU=<hostname>-talos-worker   # i9 GPU server (WOL)
