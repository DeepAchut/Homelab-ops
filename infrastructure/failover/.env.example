# infrastructure/failover/.env.example
# Copy to .env (gitignored) on the Evo-X2 host, fill in real values, then run ./evox2-readiness.sh.
# Or keep a SOPS-encrypted .env.enc.yaml in the repo and `sops -d .env.enc.yaml > .env` at use time.
# These are environment-specific infra details kept OUT of the public repo.

PBS_SERVER=            # PBS host IP (the CT200 PBS), e.g. 192.168.x.x
PBS_FINGERPRINT=       # PBS cert SHA-256 — PBS UI > Dashboard > Show Fingerprint (public cert hash, not a secret)
PBS_TOKEN_SECRET=      # API token secret for the pbs-local storage (THIS is the real secret)

# Optional overrides (have safe in-script defaults):
# PBS_DATASTORE=backup-26tb
# PBS_TOKENID=user@realm!tokenname
