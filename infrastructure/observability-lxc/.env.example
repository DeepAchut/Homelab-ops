# infrastructure/observability-lxc/.env.example
# Copy to .env (gitignored) inside CT405, set the value, then `docker compose up -d`.
# For the repo, keep the real value in a SOPS .env.enc.yaml (sops -d .env.enc.yaml > .env).

# Grafana admin password. If unset, Grafana starts with admin/admin and forces a
# change on first login — set this to skip that.
GRAFANA_ADMIN_PASSWORD=
